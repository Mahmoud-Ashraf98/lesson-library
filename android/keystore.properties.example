# APK signing config — copy this file to `keystore.properties` (gitignored)
# and fill in the real values for your keystore.
#
#   cp keystore.properties.example keystore.properties
#
# If you skip this, build-apk.ps1 auto-generates a throwaway keystore using
# the default password below, and build.gradle signs with the same default.
# That is fine for forks/dev — the APK just won't install as an update over
# the original author's build (different signing identity, by design).
#
# The original author keeps their real keystore + this file privately so their
# on-phone update channel keeps working (same applicationId, same key).

storePassword=android
keyPassword=android
keyAlias=lessonlibrary
